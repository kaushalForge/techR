<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | Admin Panel</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0a0c10 0%, #12151c 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow-x: hidden;
        }

        /* Ambient glow effects */
        .glow-1 {
            position: fixed;
            top: -20%;
            left: -20%;
            width: 80%;
            height: 80%;
            background: radial-gradient(circle, rgba(249, 115, 22, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            animation: float 20s ease-in-out infinite;
        }

        .glow-2 {
            position: fixed;
            bottom: -20%;
            right: -20%;
            width: 80%;
            height: 80%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            animation: float 25s ease-in-out infinite reverse;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            50% { transform: translate(5%, 5%) rotate(5deg); }
        }

        /* Modern glass card */
        .login-card {
            width: 100%;
            max-width: 440px;
            margin: 20px;
            background: rgba(18, 21, 28, 0.85);
            backdrop-filter: blur(20px);
            border-radius: 28px;
            padding: 40px 36px;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            position: relative;
            z-index: 10;
        }

        .login-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 50px -15px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(249, 115, 22, 0.3);
        }

        /* Title styles */
        .login-title {
            font-weight: 800;
            font-size: 32px;
            text-align: center;
            margin-bottom: 8px;
            background: linear-gradient(135deg, #ffffff 0%, #f97316 80%);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.02em;
        }

        .login-subtitle {
            text-align: center;
            color: #94a3b8;
            font-size: 14px;
            margin-bottom: 32px;
            font-weight: 400;
        }

        /* Form inputs */
        .form-label {
            font-weight: 600;
            font-size: 13px;
            color: #cbd5e1;
            margin-bottom: 8px;
            letter-spacing: 0.3px;
        }

        .input-group {
            position: relative;
            display: flex;
            align-items: stretch;
            width: 100%;
        }

        .input-group-text {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-right: none;
            color: #94a3b8;
            border-radius: 14px 0 0 14px;
            display: flex;
            align-items: center;
            padding: 12px 16px;
        }

        .form-control {
            border-radius: 0 14px 14px 0;
            padding: 12px 16px;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-left: none;
            color: #ffffff;
            font-size: 14px;
            transition: all 0.25s ease;
            width: 100%;
        }

        .form-control:focus {
            background: rgba(15, 23, 42, 0.8);
            border-color: #f97316;
            border-left-color: #f97316;
            box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.2);
            outline: none;
            color: #ffffff;
        }

        .form-control::placeholder {
            color: #64748b;
            font-weight: 400;
        }

        /* Button styles */
        .btn-primary {
            background: linear-gradient(105deg, #f97316 0%, #ea580c 100%);
            border: none;
            border-radius: 14px;
            padding: 12px;
            font-weight: 700;
            font-size: 15px;
            transition: all 0.25s ease;
            box-shadow: 0 8px 20px -6px rgba(249, 115, 22, 0.35);
            color: white;
            width: 100%;
            cursor: pointer;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 24px -8px rgba(249, 115, 22, 0.55);
            background: linear-gradient(105deg, #fb923c 0%, #f97316 100%);
        }

        .btn-outline-secondary {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 14px;
            padding: 12px;
            font-weight: 600;
            font-size: 15px;
            color: #cbd5e1;
            transition: all 0.25s ease;
            width: 100%;
            cursor: pointer;
        }

        .btn-outline-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.25);
            color: #ffffff;
            transform: translateY(-2px);
        }

        /* Alert styles */
        .alert {
            border-radius: 14px;
            padding: 12px 16px;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 20px;
            border: none;
        }

        .alert-danger {
            background: rgba(239, 68, 68, 0.15);
            backdrop-filter: blur(10px);
            color: #fca5a5;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.15);
            backdrop-filter: blur(10px);
            color: #6ee7b7;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        /* Footer */
        .footer-text {
            text-align: center;
            font-size: 11px;
            color: #475569;
            margin-top: 24px;
            letter-spacing: 0.3px;
        }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 20px 0;
            color: #475569;
            font-size: 12px;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .divider::before {
            margin-right: 12px;
        }

        .divider::after {
            margin-left: 12px;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .login-card {
                margin: 16px;
                padding: 32px 24px;
            }
            
            .login-title {
                font-size: 28px;
            }
        }
    </style>
</head>

<body>
    <!-- Ambient glow backgrounds -->
    <div class="glow-1"></div>
    <div class="glow-2"></div>

    <div class="login-card">
        <div class="login-title">Welcome Back</div>
        <div class="login-subtitle">Sign in to access your dashboard</div>

        <% if (typeof error !== "undefined") { %>
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
        </div>
        <% } %>

        <% if (typeof success !== "undefined") { %>
        <div class="alert alert-success">
            <i class="fas fa-check-circle me-2"></i> <%= success %>
        </div>
        <% } %>

        <form action="/users/login" method="POST">
            <div class="mb-4">
                <label for="email" class="form-label">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fas fa-envelope"></i>
                    </span>
                    <input
                        type="email"
                        name="email"
                        id="email"
                        class="form-control"
                        placeholder="admin@example.com"
                        required
                    />
                </div>
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input
                        type="password"
                        name="password"
                        id="password"
                        class="form-control"
                        placeholder="••••••••"
                        required
                    />
                </div>
            </div>

            <div class="d-grid gap-3 mt-4">
                <button type="submit" class="btn-primary">
                    <i class="fas fa-arrow-right-to-bracket me-2"></i> Login
                </button>
                <button type="reset" class="btn-outline-secondary">
                    <i class="fas fa-undo-alt me-2"></i> Reset
                </button>
            </div>
        </form>

        <div class="divider">Secure Access</div>

        <div class="footer-text">
            <i class="fas fa-shield-alt me-1"></i> © 2026 Admin Panel. All rights reserved.
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>