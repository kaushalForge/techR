<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechR Admin | Control Panel</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Override tailwind config to enforce dark mode and remove clutter -->
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family:
          "Inter",
          system-ui,
          -apple-system,
          sans-serif;
        background-color: #05070a;
        color: #eef2ff;
      }
      /* Custom dark-glass & refined components */
      .glass-card {
        background: rgba(15, 25, 35, 0.65);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(56, 189, 248, 0.2);
        border-radius: 1.75rem;
        transition: all 0.2s ease;
      }
      .glass-card:hover {
        border-color: rgba(56, 189, 248, 0.5);
        background: rgba(18, 28, 40, 0.8);
        box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.6);
      }
      .stat-card {
        background: #0f1219;
        border: 1px solid #1e2a3a;
        border-radius: 1.5rem;
        padding: 1.25rem 1.5rem;
        transition: all 0.2s;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.4);
      }
      .stat-card:hover {
        border-color: #3b82f6;
        transform: translateY(-2px);
      }
      .btn-glow {
        transition: all 0.2s;
        font-weight: 600;
        border-radius: 1rem;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
      }
      .btn-glow:hover {
        filter: brightness(1.08);
        transform: scale(0.98);
      }
      .toast-notification {
        position: fixed;
        bottom: 24px;
        right: 24px;
        background: #1e293b;
        backdrop-filter: blur(12px);
        border-left: 4px solid #10b981;
        padding: 12px 20px;
        border-radius: 60px;
        font-size: 0.85rem;
        font-weight: 500;
        color: #e2e8f0;
        z-index: 1000;
        opacity: 0;
        transform: translateX(40px);
        transition:
          opacity 0.25s,
          transform 0.25s;
        pointer-events: none;
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.5);
      }
      .toast-notification.show {
        opacity: 1;
        transform: translateX(0);
      }
      /* modern scroll */
      ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #0a0f16;
      }
      ::-webkit-scrollbar-thumb {
        background: #2d3a48;
        border-radius: 12px;
      }
      button,
      a {
        cursor: pointer;
      }
      .action-icon {
        transition: all 0.2s;
      }
      /* remove default link underlines */
      a {
        text-decoration: none;
      }
    </style>
  </head>
  <body class="antialiased">
    <%- include("Navbar") %>

    <main class="max-w-7xl mx-auto px-5 sm:px-8 py-9 md:py-12">
      <!-- Header with modern glow -->
      <div class="mb-10">
        <h1
          class="text-5xl md:text-6xl font-black tracking-tight bg-gradient-to-r from-slate-100 via-cyan-200 to-blue-400 bg-clip-text text-transparent"
        >
          Manipulate Items
        </h1>
        <p class="text-gray-400 mt-2 text-base border-l-3 border-cyan-500 pl-4">
          product engine · live metrics & real inventory control
        </p>
      </div>

      <!-- STATS CARDS - fully dynamic from API -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
        <div class="stat-card">
          <div
            class="text-gray-300 text-sm uppercase tracking-wider font-semibold"
          >
            Total Products
          </div>
          <div class="text-4xl font-extrabold mt-2 text-white" id="statTotal">
            —
          </div>
          <div class="text-xs text-cyan-400/70 mt-2 flex items-center gap-1">
            📦 live catalog
          </div>
        </div>
        <div class="stat-card">
          <div
            class="text-gray-300 text-sm uppercase tracking-wider font-semibold"
          >
            Phones
          </div>
          <div
            class="text-4xl font-extrabold mt-2 text-sky-400"
            id="statPhones"
          >
            —
          </div>
          <div class="text-xs text-gray-500 mt-2">📱 mobile devices</div>
        </div>
        <div class="stat-card">
          <div
            class="text-gray-300 text-sm uppercase tracking-wider font-semibold"
          >
            Laptops
          </div>
          <div
            class="text-4xl font-extrabold mt-2 text-emerald-400"
            id="statLaptops"
          >
            —
          </div>
          <div class="text-xs text-gray-500 mt-2">
            💻 notebooks & ultrabooks
          </div>
        </div>
        <div class="stat-card">
          <div
            class="text-gray-300 text-sm uppercase tracking-wider font-semibold"
          >
            Tablets
          </div>
          <div
            class="text-4xl font-extrabold mt-2 text-purple-400"
            id="statTablets"
          >
            —
          </div>
          <div class="text-xs text-gray-500 mt-2">📟 iPad & android tabs</div>
        </div>
      </div>

      <!-- ACTION CARDS : streamlined, only essential CRUD + sitemap + browse -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Sellings / add & delete -->
        <div class="glass-card p-6">
          <div class="flex items-center gap-3 mb-4">
            <div
              class="w-10 h-10 bg-gradient-to-br from-orange-500 to-rose-600 rounded-xl flex items-center justify-center shadow-md"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 6v6m0 0v6m0-6h6m-6 0H6"
                ></path>
              </svg>
            </div>
            <h2 class="text-xl font-bold text-white">Inventory Ops</h2>
          </div>
          <p class="text-gray-300 text-sm mb-5 opacity-80">
            Add new products or remove existing items from the database.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/products/addProduct"
              class="btn-glow bg-gradient-to-r from-amber-500 to-orange-600 px-5 py-2.5 text-white text-sm inline-flex items-center gap-2"
              >➕ Add Items</a
            >
            <a
              href="/delete/product"
              class="btn-glow bg-gradient-to-r from-rose-700 to-red-700 px-5 py-2.5 text-white text-sm inline-flex items-center gap-2"
              >🗑️ Delete Items</a
            >
          </div>
        </div>

        <!-- Sitemap update (minimal) -->
        <div class="glass-card p-6">
          <div class="flex items-center gap-3 mb-4">
            <div
              class="w-10 h-10 bg-gradient-to-br from-yellow-500 to-amber-600 rounded-xl flex items-center justify-center"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
                ></path>
              </svg>
            </div>
            <h2 class="text-xl font-bold text-white">SEO Sitemap</h2>
          </div>
          <p class="text-gray-300 text-sm mb-5">
            Generate XML sitemap after inventory updates.
          </p>
          <a
            href="/sitemap"
            class="btn-glow bg-gradient-to-r from-amber-500/90 to-yellow-600 px-5 py-2.5 text-white text-sm inline-flex items-center gap-2 w-fit"
            >🗺️ Update Sitemap</a
          >
        </div>

        <!-- Category browsing - clean links -->
        <div class="glass-card p-6">
          <div class="flex items-center gap-3 mb-4">
            <div
              class="w-10 h-10 bg-gradient-to-br from-cyan-500 to-indigo-600 rounded-xl flex items-center justify-center"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
                ></path>
              </svg>
            </div>
            <h2 class="text-xl font-bold text-white">Browse by Type</h2>
          </div>
          <p class="text-gray-300 text-sm mb-5">
            Quick access to filtered collections.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/phones"
              class="btn-glow bg-sky-700/80 hover:bg-sky-600 px-5 py-2 text-white text-sm rounded-xl"
              >📱 Phones</a
            >
            <a
              href="/laptops"
              class="btn-glow bg-emerald-700/80 hover:bg-emerald-600 px-5 py-2 text-white text-sm rounded-xl"
              >💻 Laptops</a
            >
            <a
              href="/tablets"
              class="btn-glow bg-purple-700/80 hover:bg-purple-600 px-5 py-2 text-white text-sm rounded-xl"
              >📟 Tablets</a
            >
          </div>
        </div>
      </div>

      <!-- Live product preview + latest items (extra utility) -->
      <div class="mt-12 glass-card p-6">
        <div class="flex items-center justify-between mb-5 flex-wrap gap-3">
          <div>
            <h3 class="text-xl font-bold text-white flex items-center gap-2">
              📡 Real‑time product feed
            </h3>
            <p class="text-gray-400 text-sm">
              latest entries from
              <span class="text-cyan-400">/api/products</span> — dynamic
              filtering by type
            </p>
          </div>
          <button
            id="refreshDataBtn"
            class="text-xs bg-gray-800 hover:bg-gray-700 px-4 py-2 rounded-full transition-all flex items-center gap-1"
          >
            ⟳ Sync now
          </button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="border-b border-gray-800">
              <tr class="text-left text-gray-300">
                <th class="pb-3 font-semibold">Product</th>
                <th class="pb-3 font-semibold">Type</th>
                <th class="pb-3 font-semibold">ID</th>
                <th class="pb-3 font-semibold text-right">Action</th>
              </tr>
            </thead>
            <tbody id="productTableBody">
              <tr>
                <td colspan="4" class="text-center py-8 text-gray-500">
                  ⟳ loading products from backend...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <div
          class="text-right text-[11px] text-gray-500 mt-4 border-t border-gray-800/50 pt-3"
        >
          ⚡ data sourced from /api/products · productType = phone, laptop,
          tablet
        </div>
      </div>

      <!-- minimalist quick tip panel (removed clutter, kept essence) -->
      <div
        class="mt-8 glass-card p-5 flex flex-wrap justify-between items-center gap-3"
      >
        <div class="flex gap-4 text-xs text-gray-300">
          <span class="flex items-center gap-1"
            >✨ <span>Add/delete syncs inventory</span></span
          >
          <span class="flex items-center gap-1"
            >🌗 <span>dark theme persistent</span></span
          >
          <span class="flex items-center gap-1"
            >🔗 <span>update sitemap after changes</span></span
          >
        </div>
        <div class="text-cyan-400 text-xs">admin ready · zero bloat</div>
      </div>
    </main>

    <div id="globalToast" class="toast-notification"></div>

    <script>
      const apiURL = "<%= backendURL %>/api/products";
      // ===================== DARK THEME: ULTRA CLEAN & PERSISTENT ==================
      (function () {
        const html = document.documentElement;
        const stored = localStorage.getItem("theme_dark_admin");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        // we enforce dark always? But we also give toggle to switch? but the requirement says "modern darkkk theme removing unnecessary things"
        // So we force dark + user can toggle to light? to give flexibility but default is hard DARK.
        // However to respect UX we set dark always, but toggle can switch to light if user wants (optional but minimal)
        const setTheme = (isDark) => {
          if (isDark) {
            html.classList.add("dark");
            document.body.style.backgroundColor = "#05070a";
            document.body.style.color = "#eef2ff";
          } else {
            html.classList.remove("dark");
            document.body.style.backgroundColor = "#f1f5f9";
            document.body.style.color = "#0f172a";
            // adjust card backgrounds for light mode? But we want dark theme primary. but we remove complexity
            // just in case toggle still works but primary design is dark. keep it minimal.
          }
          localStorage.setItem("theme_dark_admin", isDark ? "dark" : "light");
        };
        // initial: default dark (true)
        let isDarkMode = true;
        if (stored === "light") isDarkMode = false;
        else if (stored === "dark") isDarkMode = true;
        else isDarkMode = true; // enforce dark default
        setTheme(isDarkMode);
        const toggleBtn = document.getElementById("themeToggleDark");
        if (toggleBtn) {
          toggleBtn.addEventListener("click", () => {
            isDarkMode = !isDarkMode;
            setTheme(isDarkMode);
            showToast(
              `Theme switched to ${isDarkMode ? "deep dark" : "light"} mode`,
              true,
            );
          });
        }
      })();

      // Toast helper
      function showToast(message, isSuccess = true) {
        const toast = document.getElementById("globalToast");
        if (!toast) return;
        toast.innerHTML = `<span class="flex items-center gap-2">${isSuccess ? "✓" : "⚠️"} ${message}</span>`;
        toast.classList.add("show");
        setTimeout(() => toast.classList.remove("show"), 2700);
      }
      window.showToast = showToast;

      let allProductsCache = []; // store all products for stats and table
      async function fetchProductsAndRender() {
        try {
          const response = await fetch(apiURL);
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const products = await response.json();
          if (!Array.isArray(products)) throw new Error("Invalid data format");
          allProductsCache = products;

          // compute counts based on productType (phone, laptop, tablet)
          let phones = 0,
            laptops = 0,
            tablets = 0;
          for (let p of products) {
            const type = (
              p.productType ||
              p.type ||
              p.category ||
              ""
            ).toLowerCase();
            if (type === "phone" || type === "phones") phones++;
            else if (type === "laptop" || type === "laptops") laptops++;
            else if (type === "tablet" || type === "tablets") tablets++;
            else {
              // fallback: check if name includes? but keep exact match from spec: productType filter.
              // also some api may have 'productType' field, handle both.
              if (p.productType === "phone") phones++;
              else if (p.productType === "laptop") laptops++;
              else if (p.productType === "tablet") tablets++;
            }
          }
          // update stat cards
          document.getElementById("statTotal").innerText = products.length;
          document.getElementById("statPhones").innerText = phones;
          document.getElementById("statLaptops").innerText = laptops;
          document.getElementById("statTablets").innerText = tablets;

          // render table: show max 8 latest items (most recent first based on id or any)
          const tableBody = document.getElementById("productTableBody");
          if (!tableBody) return;
          const sorted = [...products].reverse().slice(0, 8);
          if (sorted.length === 0) {
            tableBody.innerHTML =
              '<tr><td colspan="4" class="text-center py-8 text-gray-400">📭 No products found in inventory</td></tr>';
            return;
          }
          tableBody.innerHTML = sorted
            .map((prod) => {
              let displayType = prod.productType || prod.type || "generic";
              if (displayType === "phone") displayType = "📱 Phone";
              else if (displayType === "laptop") displayType = "💻 Laptop";
              else if (displayType === "tablet") displayType = "📟 Tablet";
              const prodId = prod._id || prod.id || "N/A";
              const name = prod.name || prod.title || "Unnamed product";
              return `
              <tr class="border-b border-gray-800/40 hover:bg-white/5 transition">
                <td class="py-3 font-medium text-white">${escapeHtml(name)}</td>
                <td class="py-3 text-cyan-300">${escapeHtml(displayType)}</td>
                <td class="py-3 text-gray-400 font-mono text-xs">${escapeHtml(prodId.substring(0, 12))}..</td>
                <td class="py-3 text-right">
                  <button class="copyIdBtn text-xs bg-gray-700/60 hover:bg-gray-600 rounded-full px-3 py-1 transition" data-id="${prodId}">📋 Copy ID</button>
                </td>
              </tr>
            `;
            })
            .join("");

          // attach copy events
          document.querySelectorAll(".copyIdBtn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
              const id = btn.getAttribute("data-id");
              if (id) {
                navigator.clipboard
                  .writeText(id)
                  .then(() => showToast(`Copied ID: ${id}`, true))
                  .catch(() => showToast("failed to copy", false));
              }
            });
          });
          showToast(`Loaded ${products.length} products from API`, true);
        } catch (err) {
          console.error("API fetch error:", err);
          document.getElementById("statTotal").innerText = "0";
          document.getElementById("statPhones").innerText = "0";
          document.getElementById("statLaptops").innerText = "0";
          document.getElementById("statTablets").innerText = "0";
          const tableBody = document.getElementById("productTableBody");
          if (tableBody)
            tableBody.innerHTML = `<tr><td colspan="4" class="text-center py-8 text-red-400">⚠️ Failed to connect to backend: ${err.message}<br>Make sure server runs on http://localhost:5000/api/products</td></tr>`;
          showToast(`API error: ${err.message}`, false);
        }
      }

      function escapeHtml(str) {
        if (!str) return "";
        return str.replace(/[&<>]/g, function (m) {
          if (m === "&") return "&amp;";
          if (m === "<") return "&lt;";
          if (m === ">") return "&gt;";
          return m;
        });
      }

      // initial load
      fetchProductsAndRender();
      const refreshBtn = document.getElementById("refreshDataBtn");
      if (refreshBtn)
        refreshBtn.addEventListener("click", () => {
          fetchProductsAndRender();
        });

      // optional periodic subtle background refresh (every 35 seconds)
      setInterval(() => {
        fetchProductsAndRender().catch((e) =>
          console.warn("auto refresh failed", e),
        );
      }, 35000);

      window.addEventListener("pageshow", (event) => {
        if (event.persisted || document.visibilityState === "visible") {
          fetchProductsAndRender();
        }
      });
      document.addEventListener("visibilitychange", () => {
        if (!document.hidden) fetchProductsAndRender();
      });
    </script>
  </body>
</html>
