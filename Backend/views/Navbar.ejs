<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel | Navigation</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      * {
        font-family:
          "Inter",
          system-ui,
          -apple-system,
          "Segoe UI",
          sans-serif;
      }

      /* Glass morphism navbar - dark theme only */
      .glass-nav {
        background: rgba(18, 21, 28, 0.95);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 4px 20px -8px rgba(0, 0, 0, 0.3);
      }

      /* Nav link styles */
      .nav-link {
        position: relative;
        transition: all 0.25s ease;
        font-weight: 500;
        color: #cbd5e1;
        text-decoration: none;
      }

      .nav-link::after {
        content: "";
        position: absolute;
        bottom: -6px;
        left: 50%;
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, #f97316, #ea580c);
        border-radius: 2px;
        transition: all 0.3s ease;
        transform: translateX(-50%);
      }

      .nav-link:hover::after {
        width: 70%;
      }

      .nav-link:hover {
        color: #f97316;
        transform: translateY(-1px);
      }

      .nav-link.active {
        color: #f97316;
      }

      .nav-link.active::after {
        width: 70%;
      }

      /* Button styles */
      .btn-sitemap {
        background: linear-gradient(135deg, #eab308 0%, #ca8a04 100%);
        transition: all 0.25s ease;
        box-shadow: 0 2px 8px rgba(234, 179, 8, 0.25);
      }

      .btn-sitemap:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(234, 179, 8, 0.35);
      }

      .btn-logout {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        transition: all 0.25s ease;
        box-shadow: 0 2px 8px rgba(239, 68, 68, 0.25);
      }

      .btn-logout:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(239, 68, 68, 0.35);
      }

      /* Mobile menu */
      .mobile-menu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .mobile-menu.open {
        max-height: 400px;
      }

      /* Logo gradient */
      .logo-gradient {
        background: linear-gradient(135deg, #ffffff 0%, #f97316 100%);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        font-weight: 800;
        letter-spacing: -0.02em;
      }
    </style>
  </head>
  <body class="bg-gradient-to-br from-slate-900 to-slate-800 min-h-screen">
    <nav class="glass-nav sticky top-0 z-50 px-4 py-3 md:py-4">
      <div
        class="max-w-7xl mx-auto flex items-center justify-between flex-wrap gap-4"
      >
        <!-- Logo -->
        <div class="flex items-center gap-2">
          <div
            class="w-8 h-8 bg-gradient-to-br from-orange-500 to-red-600 rounded-xl flex items-center justify-center shadow-lg"
          >
            <span class="text-white font-bold text-sm">AP</span>
          </div>
          <span class="text-xl font-bold logo-gradient">Admin Panel</span>
        </div>

        <!-- Desktop Links -->
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="nav-link">Dashboard</a>
          <a href="/products/addProduct" class="nav-link">Add Product</a>
          <a href="/phones" class="nav-link">Phones</a>
          <a href="/laptops" class="nav-link">Laptops</a>
          <a href="/tablets" class="nav-link">Tablets</a>
          <a
            href="/delete/product"
            class="nav-link text-red-400 hover:text-red-500"
            >Delete</a
          >
        </div>

        <!-- Right Actions -->
        <div class="flex items-center gap-3">
          <a
            href="/sitemap"
            class="btn-sitemap px-4 py-2 text-white font-semibold rounded-xl text-sm flex items-center gap-1"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
              />
            </svg>
            Sitemap
          </a>
          <a
            href="/users/logout"
            class="btn-logout px-4 py-2 text-white font-semibold rounded-xl text-sm flex items-center gap-1"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
              />
            </svg>
            Logout
          </a>

          <!-- Mobile menu button -->
          <button
            id="mobileMenuBtn"
            class="md:hidden p-2 rounded-lg text-white hover:bg-white/10 transition-colors"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"
              />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div
        id="mobileMenu"
        class="mobile-menu md:hidden flex flex-col pb-4 space-y-2"
      >
        <a href="/" class="nav-link px-3 py-2 block">Dashboard</a>
        <a href="/products/addProduct" class="nav-link px-3 py-2 block"
          >Add Product</a
        >
        <a href="/phones" class="nav-link px-3 py-2 block">Phones</a>
        <a href="/laptops" class="nav-link px-3 py-2 block">Laptops</a>
        <a href="/tablets" class="nav-link px-3 py-2 block">Tablets</a>
        <a href="/delete/product" class="nav-link px-3 py-2 text-red-400 block"
          >Delete</a
        >
      </div>
    </nav>

    <script>
      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById("mobileMenuBtn");
      const mobileMenu = document.getElementById("mobileMenu");

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener("click", () => {
          mobileMenu.classList.toggle("open");
        });
      }

      // Active link highlighting
      const currentPath = window.location.pathname;
      document.querySelectorAll(".nav-link").forEach((link) => {
        const href = link.getAttribute("href");
        if (href && href !== "/" && currentPath.startsWith(href)) {
          link.classList.add("active");
        } else if (href === "/" && currentPath === "/") {
          link.classList.add("active");
        }
      });
    </script>
  </body>
</html>
